{
  "slides": {
    "M01-title": {
      "section": "模块标题",
      "title": "Module 01",
      "subtitle": "开场与认知重构",
      "description": "Day 1 上午 | 90分钟",
      "notes": "这是课程最关键的开场设计。如果开场失败，后面所有内容都会大打折扣。"
    },
    "M01-objectives": {
      "section": "模块标题",
      "title": "学习目标",
      "studentContent": "\n          <p style=\"margin-bottom: 20px;\">完成本模块后，你将能够：</p>\n          <ul>\n            <li><strong>认识到</strong>\"感觉式评价\"的局限性</li>\n            <li><strong>理解</strong>\"内容操作系统\"的价值</li>\n            <li><strong>建立</strong>\"骨肉魂三层架构\"的整体印象</li>\n            <li><strong>产生</strong>学习骨肉魂框架的内在动机</li>\n          </ul>\n        ",
      "presenterContent": "\n          <div class=\"tip-box presenter-only\">\n            <strong>💡 教学提示：</strong>这4个目标是本模块的核心产出。后续所有内容设计都围绕这4个目标展开。\n          </div>\n        ",
      "notes": "快速过一下学习目标，不需要展开讲。"
    },
    "M01-part1-title": {
      "section": "1️⃣ 开场暖场",
      "title": "Part 1",
      "subtitle": "开场暖场",
      "description": "⏱ 0:00 - 0:10 | 10分钟",
      "notes": "开场的核心是建立期待感。"
    },
    "M01-1-opening": {
      "section": "1️⃣ 开场暖场",
      "title": "欢迎来到骨肉魂 Bootcamp",
      "studentContent": "\n          <div class=\"big-quote\" style=\"font-size: 32px;\">\n            \"这个视频好\"<br>到底是什么意思？\n          </div>\n          <div class=\"highlight-box\" style=\"text-align: center; font-size: 20px;\">\n            今天不是教大家拍视频<br>\n            而是教大家一套评视频、做视频的<strong>「操作系统」</strong>\n          </div>\n        ",
      "presenterContent": "\n          <div class=\"script-box presenter-only\">\n            <div class=\"script-label\">📢 讲师话术</div>\n            <div class=\"script-content\">\n              大家好，欢迎来到<em>骨肉魂 Bootcamp</em>。<br><br>\n              我们每天都在看视频、评视频、做视频...但\"这个视频好\"到底是什么意思？<br><br>\n              今天不是教大家拍视频，而是教大家一套评视频、做视频的<em>\"操作系统\"</em>。<br><br>\n              学完之后，你们可以用同一套语言讨论内容，让AI帮你写脚本。\n            </div>\n          </div>\n        ",
      "notes": "开场3句话要简洁有力。语速适中，给学员消化的时间。"
    },
    "M01-1-icebreaker": {
      "section": "1️⃣ 开场暖场",
      "title": "快速认识一下",
      "studentContent": "\n          <div class=\"interactive-badge\">🤝 互动环节</div>\n          <div class=\"highlight-box\" style=\"font-size: 22px;\">\n            <strong>15秒自我介绍：</strong><br>\n            名字 + 主负责的产品线\n          </div>\n          <div style=\"margin-top: 40px; text-align: center; color: var(--text-secondary);\">\n            <p style=\"font-size: 20px;\">在开始之前，我想问大家一个问题：</p>\n            <p style=\"font-size: 28px; color: var(--accent); margin-top: 20px;\"><strong>你们平时怎么判断一个视频好不好？</strong></p>\n          </div>\n        ",
      "presenterContent": "\n          <div class=\"tip-box presenter-only\">\n            <strong>💡 讲师提示：</strong>\n            <ul style=\"margin-top: 8px;\">\n              <li>人数>15人时，可以按组介绍或只挑部分人</li>\n              <li>这个环节不要超过5分钟</li>\n              <li>破冰问题收集2-3个回答，只说\"好，谢谢\"，不做评价</li>\n            </ul>\n          </div>\n        ",
      "notes": "破冰问题是为白纸实验埋伏笔。学员的模糊回答会印证后面的结论。"
    },
    "M01-part2-title": {
      "section": "2️⃣ 白纸实验",
      "title": "Part 2",
      "subtitle": "白纸实验",
      "description": "⏱ 0:10 - 0:45 | 35分钟",
      "notes": "白纸实验是整个模块的重心！不要省略任何环节。"
    },
    "M01-2-rules": {
      "section": "2️⃣ 白纸实验",
      "title": "实验规则",
      "studentContent": "\n          <div class=\"highlight-box\" style=\"font-size: 22px;\">\n            <strong>接下来我会播放一条视频</strong><br><br>\n            请每个人在纸上写下你的答案：<br><br>\n            <span style=\"font-size: 28px; color: var(--accent);\">「这个视频为什么好？或者为什么不好？」</span>\n          </div>\n          <div class=\"info-box\" style=\"margin-top: 24px;\">\n            ⚠️ 请独立思考，不要和旁边的人讨论\n          </div>\n        ",
      "presenterContent": "\n          <div class=\"action-box presenter-only\">\n            <strong>▶ 讲师动作：</strong>确认每个学员都有白纸和笔\n          </div>\n        ",
      "notes": "强调\"独立思考\"很重要，这样后面才能看到不同视角的差异。"
    },
    "M01-2-video": {
      "section": "2️⃣ 白纸实验",
      "title": "观看视频",
      "studentContent": "<div class=\"video-placeholder\"><div class=\"icon\">🎬</div><div style=\"font-size: 20px; color: white; margin-bottom: 16px;\">选择视频播放</div><div style=\"display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;\"><a href=\"/video-player.html?src=/videos/95c6ba719e05cfa46ee9439ba16d6a3281e3f50f_1770017078837.mp4&title=案例视频 A\" target=\"_blank\" style=\"display: inline-block; padding: 14px 28px; background: linear-gradient(135deg, #FF6B35, #FF8F5E); color: white; text-decoration: none; border-radius: 10px; font-size: 18px; font-weight: 600;\">▶ 视频 A</a><a href=\"/video-player.html?src=/videos/4bad7690df49e58e4b725a98a758690ba251d31f_1770017319924.mp4&title=案例视频 B\" target=\"_blank\" style=\"display: inline-block; padding: 14px 28px; background: linear-gradient(135deg, #4CAF50, #66BB6A); color: white; text-decoration: none; border-radius: 10px; font-size: 18px; font-weight: 600;\">▶ 视频 B</a></div><div style=\"color: var(--text-secondary); margin-top: 16px; font-size: 14px;\">点击后将在新标签页打开视频分析工具</div></div>",
      "presenterContent": "<div class=\"tip-box presenter-only\"><strong>💡 视频选择要点：</strong><br>选择<em>有争议性</em>的视频（不是绝对的爆款或绝对的失败），这样才能引发不同意见。<br>建议用公司自己的产品视频，学员更有代入感。</div>",
      "notes": "视频选择是关键！要选择能引发不同评价的视频。点击按钮后会新标签页打开骨肉魂培训助手播放器。"
    },
    "M01-2-writing": {
      "section": "2️⃣ 白纸实验",
      "title": "独立书写",
      "studentContent": "<div style=\"text-align: center;\"><div style=\"font-size: 120px; margin-bottom: 20px;\">✍️</div><div style=\"font-size: 18px; color: var(--text-secondary); margin-top: 12px;\">写几个关键词，或者写一段话，随你</div></div>",
      "presenterContent": "\n          <div class=\"action-box presenter-only\">\n            <strong>▶ 讲师动作：</strong>\n            <ul style=\"margin-top: 8px;\">\n              <li>在场地中慢慢走动，观察学员书写情况</li>\n              <li>不要看具体内容，保持神秘感</li>\n              <li>如有人讨论，轻声提醒：\"请独立思考\"</li>\n              <li>最后1分钟提醒：\"还有一分钟\"</li>\n            </ul>\n          </div>\n        ",
      "notes": "8分钟是精心设计的——足够认真思考，但不会太长。讲师要巡场但不要干预。"
    },
    "M01-2-sharing": {
      "section": "2️⃣ 白纸实验",
      "title": "分享环节",
      "studentContent": "\n          <div class=\"interactive-badge\">🤝 互动环节</div>\n          <div class=\"highlight-box\" style=\"font-size: 20px;\">\n            请几位同学分享一下你们的答案\n          </div>\n          <div style=\"display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 24px;\">\n            <div style=\"padding: 16px; background: rgba(255,255,255,0.05); border-radius: 10px;\">\n              <div style=\"color: var(--accent); font-weight: 500; margin-bottom: 8px;\">感觉型</div>\n              <div style=\"font-size: 14px; color: var(--text-secondary);\">\"感觉很有质感\"\"看起来很高级\"</div>\n            </div>\n            <div style=\"padding: 16px; background: rgba(255,255,255,0.05); border-radius: 10px;\">\n              <div style=\"color: var(--accent); font-weight: 500; margin-bottom: 8px;\">元素型</div>\n              <div style=\"font-size: 14px; color: var(--text-secondary);\">\"音乐很好听\"\"画面很美\"</div>\n            </div>\n            <div style=\"padding: 16px; background: rgba(255,255,255,0.05); border-radius: 10px;\">\n              <div style=\"color: var(--accent); font-weight: 500; margin-bottom: 8px;\">技术型</div>\n              <div style=\"font-size: 14px; color: var(--text-secondary);\">\"节奏很快\"\"转场很多\"</div>\n            </div>\n            <div style=\"padding: 16px; background: rgba(255,255,255,0.05); border-radius: 10px;\">\n              <div style=\"color: var(--accent); font-weight: 500; margin-bottom: 8px;\">模糊型</div>\n              <div style=\"font-size: 14px; color: var(--text-secondary);\">\"说不清楚为什么\"</div>\n            </div>\n          </div>\n        ",
      "presenterContent": "\n          <div class=\"tip-box presenter-only\">\n            <strong>💡 抽取策略：</strong>\n            <ul style=\"margin-top: 8px;\">\n              <li>抽取 5-8 人（根据班级大小调整）</li>\n              <li>故意选择看起来答案不同的人</li>\n              <li>不要全部抽同一个区域的人</li>\n            </ul>\n          </div>\n        ",
      "notes": "这是收集\"素材\"的环节。不同答案正是后面\"点明问题\"的证据。"
    },
    "M01-2-problem": {
      "section": "2️⃣ 白纸实验",
      "title": "发现问题",
      "studentContent": "\n          <div style=\"text-align: center; padding: 40px 0;\">\n            <div style=\"font-size: 24px; color: var(--text-secondary); margin-bottom: 30px;\">有没有发现一个问题？</div>\n            <div style=\"font-size: 48px; color: var(--accent-secondary); font-weight: bold;\">我们没有共同语言</div>\n          </div>\n        ",
      "presenterContent": "\n          <div class=\"script-box presenter-only\">\n            <div class=\"script-label\">📢 讲师话术（关键时刻！）</div>\n            <div class=\"script-content\">\n              <em>（看着大家，停顿3秒）</em><br><br>\n              有没有发现一个问题？<br><br>\n              <em>（停顿5秒，让大家思考）</em><br><br>\n              <strong style=\"font-size: 20px;\">我们没有共同语言。</strong>\n            </div>\n          </div>\n          <div class=\"warning-box presenter-only\">\n            <strong>⚠️ 语气要点：</strong>这句话要说得<em>平静、缓慢</em>，不是责备，是陈述事实。让学员自己感受问题的严重性。\n          </div>\n        ",
      "notes": "这是整个白纸实验的高潮点！\"我们没有共同语言\"要有足够的停顿和重量。"
    },
    "M01-2-consequence": {
      "section": "2️⃣ 白纸实验",
      "title": "这意味着什么？",
      "studentContent": "\n          <div class=\"slide-body\">\n            <p style=\"font-size: 20px; margin-bottom: 24px;\">刚才大家的答案都很有道理。但我们评价的角度完全不一样：</p>\n            <ul style=\"font-size: 18px; margin-bottom: 30px;\">\n              <li>有人说感觉，有人说画面</li>\n              <li>有人说数据，有人说说不清楚...</li>\n            </ul>\n            <div class=\"highlight-box\" style=\"font-size: 20px;\">\n              如果一个团队没有统一的评价结构，就<strong>无法复制成功</strong>\n            </div>\n            <div class=\"big-quote\" style=\"margin-top: 20px;\">\"你的爆款是运气，不是能力。\"</div>\n          </div>\n        ",
      "notes": "核心论点：没有共同语言 = 无法复制成功 = 爆款靠运气。"
    },
    "M01-2-classify": {
      "section": "2️⃣ 白纸实验",
      "title": "三格分类实验",
      "studentContent": "\n          <div class=\"interactive-badge\">🤝 互动环节</div>\n          <div class=\"highlight-box\">\n            <strong>请完成以下任务：</strong>\n            <ol style=\"margin-top: 12px; padding-left: 20px;\">\n              <li style=\"margin-bottom: 8px;\">看看你白纸上写的那些评价词</li>\n              <li style=\"margin-bottom: 8px;\">试着把它们分成<strong>三类</strong>，填入三个格子</li>\n              <li>给每个格子起一个<strong>标题</strong></li>\n            </ol>\n          </div>\n          <div class=\"info-box\" style=\"margin-top: 20px;\">\n            没有标准答案。你觉得怎么分就怎么分。<br>\n            ⏱ 时间：5分钟\n          </div>\n        ",
      "presenterContent": "\n          <div class=\"action-box presenter-only\">\n            <strong>▶ 讲师动作：</strong>分发三格纸，准备剪刀和胶棒（或让学员直接用笔抄写分类）\n          </div>\n          <div class=\"tip-box presenter-only\">\n            <strong>💡 常见的学员分类方式：</strong>\n            <ul style=\"margin-top: 8px;\">\n              <li>「视觉 / 听觉 / 感觉」</li>\n              <li>「内容 / 形式 / 效果」</li>\n              <li>「好的 / 一般的 / 不确定」</li>\n            </ul>\n          </div>\n        ",
      "notes": "这个环节让学员主动发现\"需要统一框架\"，而不是被动接受。"
    },
    "M01-2-discovery": {
      "section": "2️⃣ 白纸实验",
      "title": "展示与发现",
      "studentContent": "\n          <div style=\"text-align: center; padding: 30px 0;\">\n            <div style=\"font-size: 22px; margin-bottom: 30px;\">每个人分的类不一样，起的名字也不一样</div>\n            <div style=\"font-size: 28px; color: var(--accent);\">这说明什么？</div>\n            <div style=\"font-size: 20px; color: var(--text-secondary); margin-top: 30px;\">\n              如果团队里每个人的分类方式都不一样，<br>还是没有共同语言...\n            </div>\n          </div>\n        ",
      "presenterContent": "\n          <div class=\"script-box presenter-only\">\n            <div class=\"script-label\">📢 讲师话术</div>\n            <div class=\"script-content\">\n              请几位同学举起你们的三格纸，让大家看看。<br><br>\n              <em>（看着展示的分类）</em>有意思...<br><br>\n              大家有没有发现？每个人分的类不一样，起的名字也不一样。<br>\n              这说明什么？\n            </div>\n          </div>\n          <div class=\"tip-box presenter-only\">\n            <strong>🎯 关键时刻：</strong>引导学员自己说出\"我们需要统一的分类标准\"\n          </div>\n        ",
      "notes": "这是让学员\"顿悟\"的时刻。要引导他们自己发现。"
    },
    "M01-2-mission": {
      "section": "2️⃣ 白纸实验",
      "title": "今天的使命",
      "studentContent": "\n          <div class=\"slide-body\" style=\"text-align: center;\">\n            <p style=\"font-size: 20px; margin-bottom: 30px;\">今天我们要做的事情是：</p>\n            <div style=\"font-size: 22px; margin-bottom: 16px;\">1️⃣ <strong>统一</strong>这三个格子的标题</div>\n            <div style=\"font-size: 22px; margin-bottom: 40px;\">2️⃣ 把每个格子里的内容做<strong>细致的拆解</strong></div>\n            <div style=\"font-size: 18px; color: var(--text-secondary); margin-bottom: 20px;\">这就是我们今天要学的系统——</div>\n            <div style=\"font-size: 56px; color: var(--accent); font-weight: bold;\">骨 · 肉 · 魂</div>\n          </div>\n        ",
      "notes": "骨肉魂框架正式登场！从学员的分类实验自然过渡。"
    },
    "M01-2-before-after": {
      "section": "2️⃣ 白纸实验",
      "title": "BEFORE vs AFTER",
      "studentContent": "\n          <div class=\"comparison-box\">\n            <div class=\"comparison-before\">\n              <div class=\"comparison-label\">❌ BEFORE: 白纸式评价</div>\n              <ul style=\"margin-top: 12px; font-size: 16px; list-style: none; padding: 0;\">\n                <li style=\"padding: 6px 0;\">\"这个视频很有质感\"</li>\n                <li style=\"padding: 6px 0;\">\"音乐很好听\"</li>\n                <li style=\"padding: 6px 0;\">\"感觉很高级\"</li>\n              </ul>\n              <div style=\"margin-top: 16px; font-size: 14px; color: #f44336;\">\n                ✗ 无法复制 ✗ 无法传承 ✗ 无法优化\n              </div>\n            </div>\n            <div class=\"comparison-after\">\n              <div class=\"comparison-label\">✅ AFTER: 结构化分析</div>\n              <ul style=\"margin-top: 12px; font-size: 15px; list-style: none; padding: 0;\">\n                <li style=\"padding: 6px 0;\">【骨】HOOK用SUSPENSE_QUESTION，策略HAND，结构HPVC</li>\n                <li style=\"padding: 6px 0;\">【魂】目标人群新手妈妈，情绪焦虑→认同→希望</li>\n                <li style=\"padding: 6px 0;\">【肉】节奏high，真人口播，剪辑密度高</li>\n              </ul>\n              <div style=\"margin-top: 16px; font-size: 14px; color: #4CAF50;\">\n                ✓ 可复制 ✓ 可传承 ✓ 可优化\n              </div>\n            </div>\n          </div>\n        ",
      "presenterContent": "\n          <div class=\"script-box presenter-only\">\n            <div class=\"script-label\">📢 讲师话术</div>\n            <div class=\"script-content\">\n              <em>（展示 BEFORE）</em>这是我们今天的起点。<br><br>\n              <em>（展示 AFTER）</em>这是我们两天后的终点。<br><br>\n              当你能用这样的语言来评价一条视频的时候，<br>\n              你就不再是\"拍视频的人\"——<br>\n              <em>你是\"内容系统的设计师\"。</em>\n            </div>\n          </div>\n        ",
      "notes": "视觉冲击最强的对比！AFTER的具体内容先不解释，留悬念。"
    },
    "M01-part3-title": {
      "section": "3️⃣ 认知重构",
      "title": "Part 3",
      "subtitle": "认知重构",
      "description": "⏱ 0:45 - 1:30 | 45分钟",
      "notes": "认知重构部分可以稍快讲，详细内容会在后续模块展开。"
    },
    "M01-3-why-os": {
      "section": "3️⃣ 认知重构",
      "title": "为什么需要\"操作系统\"",
      "studentContent": "\n          <table style=\"width: 100%; border-collapse: collapse; font-size: 16px;\">\n            <tr style=\"background: rgba(255,255,255,0.1);\">\n              <th style=\"padding: 14px; text-align: left; border-bottom: 1px solid #444;\">维度</th>\n              <th style=\"padding: 14px; text-align: left; border-bottom: 1px solid #444; color: #f44336;\">感觉评价</th>\n              <th style=\"padding: 14px; text-align: left; border-bottom: 1px solid #444; color: #4CAF50;\">操作系统</th>\n            </tr>\n            <tr>\n              <td style=\"padding: 14px; border-bottom: 1px solid #333;\">词汇</td>\n              <td style=\"padding: 14px; border-bottom: 1px solid #333;\">\"抓人\"\"有感觉\"\"舒服\"</td>\n              <td style=\"padding: 14px; border-bottom: 1px solid #333;\">\"HOOK-PROBLEM-VALUE-CTA\"</td>\n            </tr>\n            <tr>\n              <td style=\"padding: 14px; border-bottom: 1px solid #333;\">可复制性</td>\n              <td style=\"padding: 14px; border-bottom: 1px solid #333;\">低（依赖个人经验）</td>\n              <td style=\"padding: 14px; border-bottom: 1px solid #333;\">高（可教、可学、可迭代）</td>\n            </tr>\n            <tr>\n              <td style=\"padding: 14px; border-bottom: 1px solid #333;\">与AI协作</td>\n              <td style=\"padding: 14px; border-bottom: 1px solid #333;\">困难（AI不懂感觉）</td>\n              <td style=\"padding: 14px; border-bottom: 1px solid #333;\">高效（结构化输入=结构化输出）</td>\n            </tr>\n            <tr>\n              <td style=\"padding: 14px;\">团队沟通</td>\n              <td style=\"padding: 14px;\">\"你懂我意思吗？\"</td>\n              <td style=\"padding: 14px;\">\"这个HOOK用了L2-Question\"</td>\n            </tr>\n          </table>\n        ",
      "presenterContent": "\n          <div class=\"tip-box presenter-only\">\n            <strong>💡 重点强调：</strong>\"与AI协作\"这一行——这是学员最关心的实用价值。\n          </div>\n        ",
      "notes": "用对比表格让学员清楚看到两种模式的差异。"
    },
    "M01-3-overview": {
      "section": "3️⃣ 认知重构",
      "title": "骨肉魂三层架构",
      "studentContent": "\n          <div class=\"three-layer\">\n            <div class=\"layer-box layer-bone\">\n              <h3>骨</h3>\n              <h4>Bone</h4>\n              <p><strong>怎么结构？</strong></p>\n              <p style=\"margin-top: 8px; font-size: 13px;\">Skeleton 骨架类型<br>Strategy 说服技法</p>\n            </div>\n            <div class=\"layer-box layer-soul\">\n              <h3>魂</h3>\n              <h4>Soul</h4>\n              <p><strong>为什么打动人？</strong></p>\n              <p style=\"margin-top: 8px; font-size: 13px;\">目标人群、触发场景<br>奖赏类型、冲突类型、情绪轨迹</p>\n            </div>\n            <div class=\"layer-box layer-meat\">\n              <h3>肉</h3>\n              <h4>Meat</h4>\n              <p><strong>怎么呈现？</strong></p>\n              <p style=\"margin-top: 8px; font-size: 13px;\">画面、声音、节奏<br>字幕、特效、时长</p>\n            </div>\n          </div>\n        ",
      "presenterContent": "\n          <div class=\"script-box presenter-only\">\n            <div class=\"script-label\">📢 讲师话术</div>\n            <div class=\"script-content\">\n              <strong style=\"color: #FFB74D;\">骨</strong>，回答的是\"怎么结构\"的问题。内容的骨架是什么？用什么策略来说服人？<br><br>\n              <strong style=\"color: #BA68C8;\">魂</strong>，回答的是\"为什么能打动人\"。触发了什么情绪？提供了什么奖赏？解决了什么心理冲突？<br><br>\n              <strong style=\"color: #81C784;\">肉</strong>，回答的是\"看起来和听起来怎么样\"。用什么画面、什么节奏、什么声音。\n            </div>\n          </div>\n        ",
      "notes": "骨肉魂框架的第一次正式亮相。让学员建立整体印象。"
    },
    "M01-3-order": {
      "section": "3️⃣ 认知重构",
      "title": "为什么是 骨 → 魂 → 肉",
      "studentContent": "\n          <div class=\"slide-body\">\n            <ul style=\"font-size: 20px;\">\n              <li><strong style=\"color: #FFB74D;\">1. 骨架先行：</strong>没有结构，情感和视觉都是散的</li>\n              <li><strong style=\"color: #BA68C8;\">2. 灵魂次之：</strong>知道结构后，才能理解每个段落的情感设计</li>\n              <li><strong style=\"color: #81C784;\">3. 肉体最后：</strong>视觉是服务于结构和情感的</li>\n            </ul>\n            <div class=\"info-box\" style=\"margin-top: 30px;\">\n              <strong>⚠️ 常见误区：</strong>很多人喜欢先学\"怎么拍得好看\"，但\"好看\"必须有明确的结构目标才有意义。\n            </div>\n          </div>\n        ",
      "notes": "解释学习顺序的逻辑。纠正\"先学拍摄技巧\"的误区。"
    },
    "M01-3-closing": {
      "section": "3️⃣ 认知重构",
      "title": "认知转变",
      "studentContent": "\n          <div style=\"text-align: center; padding: 30px 0;\">\n            <div style=\"font-size: 20px; color: var(--text-secondary); margin-bottom: 30px;\">\n              当你再看到一条视频的时候，不要问：\n            </div>\n            <div style=\"font-size: 24px; color: #f44336; text-decoration: line-through; margin-bottom: 30px;\">\n              \"这个视频好不好？\"\n            </div>\n            <div style=\"font-size: 20px; color: var(--text-secondary); margin-bottom: 20px;\">\n              而要问：\n            </div>\n            <div style=\"font-size: 28px; color: var(--accent);\">\n              \"这个视频的<strong>骨</strong>是什么？<strong>魂</strong>是什么？<strong>肉</strong>是什么？\"\n            </div>\n          </div>\n        ",
      "presenterContent": "\n          <div class=\"tip-box presenter-only\">\n            <strong>🎯 认知转变检验：</strong>学员应该从\"好不好\" → \"骨/魂/肉是什么\"\n          </div>\n        ",
      "notes": "模块收尾。确保学员完成了认知转变再继续。"
    },
